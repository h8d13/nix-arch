#!/bin/sh -e
# Make an imported generation bootable. import-path lands a shipped
# generation in the store with no GRUB entry, and nixgen-commit cannot
# adopt it (commit snapshots the running root into a new path).
# Validate the path can boot at all, then append the same entries.cfg
# stanza commit writes.
# usage: nixgen-adopt <store-path-basename> [store-root]
#        store-root default /nixstoredev
GEN=$1
TARGET=${2:-/nixstoredev}
[ -n "$GEN" ] || { echo "usage: $0 <store-path-basename> [store-root]" >&2; exit 1; }
DIR=$TARGET/nix/store/$GEN
[ -d "$DIR" ] || { echo "no $DIR: import-path the bundle first" >&2; exit 1; }
[ -f "$DIR/boot/vmlinuz-linux" ] && [ -f "$DIR/boot/initramfs-linux.img" ] || {
	echo "$GEN carries no kernel+initramfs: refusing a boot entry" >&2
	exit 1
}
# nixgen-entry refuses duplicates and roots the path: an adopted
# (import-path'd) generation may predate its root
/usr/local/lib/nixgen-entry "$TARGET" "$GEN" adopted
echo "adopted: $GEN (GRUB entry added, visible next boot)"
