#!/bin/sh -e
# Stream committed generations to stdout in export wire format, from
# inside the box: the sending half of box-to-box shipping. Reads the
# store disk (the ISO squashfs carries no db, so only committed
# generations are sendable). export-path re-hashes against the db, a
# locally corrupted generation refuses to leave.
# usage: nixgen-send <name|id>... > bundle
#        nixgen-send <name|id>... | ssh other-box nixgen-recv
[ $# -ge 1 ] || { echo "usage: $0 <name|id>... > bundle" >&2; exit 1; }
[ -d /nixstoredev ] || {
	echo "no writable store: boot with a NIXSTORE disk attached" >&2
	exit 1
}

RESOLVED=
for GEN in "$@"; do
	# bare names and hash-prefix ids resolve to <hash>-<name> when
	# exactly one generation on the disk matches (nixgen-remove rules)
	if [ ! -d "/nixstoredev/nix/store/$GEN" ]; then
		n=0
		for m in /nixstoredev/nix/store/*-"$GEN"; do
			[ -d "$m" ] && { n=$((n + 1)); match=${m##*/}; }
		done
		if [ "$n" -eq 0 ]; then
			for m in "/nixstoredev/nix/store/$GEN"*; do
				[ -d "$m" ] && { n=$((n + 1)); match=${m##*/}; }
			done
		fi
		if [ "$n" -eq 1 ]; then
			GEN=$match
		elif [ "$n" -gt 1 ]; then
			echo "ambiguous name '$GEN' ($n matches), use the full basename" >&2
			exit 1
		else
			echo "not on the store disk: $GEN" >&2
			exit 1
		fi
	fi
	RESOLVED="$RESOLVED $GEN"
done

# shellcheck disable=SC2086: store basenames never contain spaces
LD_LIBRARY_PATH=/usr/local/lib exec /usr/local/bin/export-path /nixstoredev $RESOLVED
