#!/bin/sh -e
# Receive a nixgen-send bundle on stdin: import into the store disk
# (CA-verified: content that does not hash back to its claimed path is
# refused), dedup against the farm, then append a GRUB entry for every
# imported generation that carries a kernel, same shape nixgen-commit
# writes. Data-only paths import fine and just get no menu entry.
# usage: nixgen-recv < bundle
#        nixgen-send <gen> | ssh this-box nixgen-recv
[ -d /nixstoredev ] || {
	echo "no writable store: boot with a NIXSTORE disk attached" >&2
	exit 1
}

IMPORTED=$(LD_LIBRARY_PATH=/usr/local/lib /usr/local/bin/import-path /nixstoredev)
[ -n "$IMPORTED" ] || { echo "nothing imported" >&2; exit 1; }

# same kernel params as the running system, minus the generation
# selector and GRUB's own bookkeeping
CMDLINE=$(tr ' ' '\n' < /proc/cmdline \
	| grep -v '^nixgen=\|^nixsource=\|^BOOT_IMAGE=\|^initrd=\|^$' | tr '\n' ' ')

for NEW in $IMPORTED; do
	GEN=$(basename "$NEW")
	if [ ! -f "$NEW/boot/vmlinuz-linux" ]; then
		echo "received: $GEN (no kernel, no GRUB entry)"
		continue
	fi
	# re-received generation: entry already present, don't duplicate
	if [ -f /nixstoredev/entries.cfg ] \
			&& grep -q "nixgen=$GEN " /nixstoredev/entries.cfg; then
		echo "received: $GEN (GRUB entry already present)"
		continue
	fi
	cat >> /nixstoredev/entries.cfg <<EOF
menuentry "nixarch: $GEN (received)" {
	search --no-floppy --set=nixdev --label NIXSTORE
	linux (\$nixdev)/nix/store/$GEN/boot/vmlinuz-linux nixgen=$GEN nixsource=disk $CMDLINE
	initrd (\$nixdev)/nix/store/$GEN/boot/initramfs-linux.img
}
EOF
	echo "received: $GEN (GRUB entry added, visible next boot)"
done
